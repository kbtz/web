{
	"include": [
		"**/ambient.d.ts",
		"*/main.ts",
		"vite.config.ts"
	],
	"exclude": [
		"npm",
		"tsd"
	],
	"compilerOptions": {
		"baseUrl": ".",
		"typeRoots": [
			"tsd"
		],
		"paths": {
			":*": [
				"npm/*"
			],
			";*": [
				"tsd/*"
			]
		},
		"lib": [
			"esnext",
			"dom"
		],
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "node",
	}
}